<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>home</title>
    <link rel="stylesheet" href="/public/css/home.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="/public/js/home.js"></script>
</head>

<body>
    <div class="sidebar">
        <h2>Quản lý học sinh</h2>
        <button onclick="window.location.href='/'">Thông tin cá nhân</button>
        <input type="hidden" id="ID" value="<%= data.id %>">
        <% switch (data.role) { case 'admin' : %>
            <button onclick="showSubject()">Lớp học</button>
            <button onclick="showAdd()">Thêm</button>
            <% break; case 'teacher' : %>
                <button onclick="showSubject()">Lớp học</button>
                <% break; case 'student' : %>
                    <button onclick="showScore()">Kết quả học tập</button>
                    <% break; } %>
    </div>

    <div class="main" id="mainContent">
        <h3>Chào mừng đến quản lý học sinh</h3>
        <div style="display: flex; gap: 20px; margin-top: 20px;">

            <div style="flex: 1; padding: 20px; border: 1px solid #ccc; border-radius: 10px; background-color: #fff;">
                <h4>Thông tin cá nhân</h4>
                <p><strong>Tên:</strong>
                    <%= data.name %>
                </p>
                <p><strong>Vai trò:</strong>
                    <% switch (data.role) { case 'admin' : %>
                        Quản trị viên
                        <% break; case 'teacher' : %>
                            Giáo viên
                            <% break; case 'student' : %>
                                Học sinh
                                <% break; } %>
                </p>
            </div>

            <div style="display: flex; flex-direction: column; gap: 10px;">
                <button onclick="logout()"
                    style="padding: 10px 20px; border: none; background-color: #dc3545; color: white; border-radius: 5px; cursor: pointer;">
                    Đăng xuất
                </button>
            </div>

        </div>
    </div>

</body>

</html>