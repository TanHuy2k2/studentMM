<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>home</title>
    <link rel="stylesheet" href="/public/css/home.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/paginationjs/2.1.5/pagination.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/paginationjs/2.1.5/pagination.min.js"></script>
    <script src="/public/js/subject.js"></script>
    <script src="/public/js/class.js"></script>
    <script src="/public/js/score.js"></script>
    <script src="/public/js/student.js"></script>
    <script src="/public/js/teacher.js"></script>
</head>

<body>
    <div class="sidebar">
        <h2>Quản lý học sinh</h2>
        <button onclick="window.location.href='/'">Thông tin cá nhân</button>
        <input type="hidden" id="ID" value="<%= data.id %>">
        <% switch (data.role) { case 'admin' : %>
            <button onclick="showClass()">Lớp học</button>
            <button onclick="showStudent()">Học sinh</button>
            <button onclick="showTeacher()">Giáo viên</button>
            <button onclick="showSubject()">Môn học</button>
            <% break; case 'teacher' : %>
                <button onclick="showSubjectTeacher()">Môn học</button>
                <% break; case 'student' : %>
                    <button onclick="showScore()">Kết quả học tập</button>
                    <button onclick="showSubjectForRegister()">Đăng kí môn học</button>
                    <% break; } %>
    </div>

    <div style="display: block; width: 90%;">
        <div class="main" id="mainContent">
            <h3>Chào mừng đến quản lý học sinh</h3>
            <div style="display: flex; gap: 20px; margin-top: 20px;">
                <div
                    style="flex: 1; padding: 20px; border: 1px solid #ccc; border-radius: 10px; background-color: #fff;">
                    <h4>Thông tin cá nhân</h4>
                    <p><strong>Tên:</strong>
                        <%= data.name %>
                    </p>
                    <p><strong>Vai trò:</strong>
                        <% switch (data.role) { case 'admin' : %>
                            Quản trị viên
                            <% break; case 'teacher' : %>
                                Giáo viên
                                <% break; case 'student' : %>
                                    Học sinh
                                    <% break; } %>
                    </p>
                </div>

                <div style="display: flex; flex-direction: column; gap: 10px;">
                    <button onclick="logout()"
                        style="padding: 10px 20px; border: none; background-color: #dc3545; color: white; border-radius: 5px; cursor: pointer;">
                        Đăng xuất
                    </button>
                </div>
            </div>
        </div>
        <div id="pagging" style="display: none; margin-top: 20px; align-items: center; justify-items: center;"></div>
    </div>

</body>
<script>
    function logout() {
        $.ajax({
            url: '/account/logout',
            type: 'GET',
        }).then(response => {
            if (response.success) {
                alert("Đăng xuất thành công!");
                window.location.href = "/";
            } else {
                alert("Đăng xuất thất bại!");
            }
        }).catch(error => {
            alert("Đã xảy ra lỗi khi đăng xuất.");
        });
    }
</script>

</html>